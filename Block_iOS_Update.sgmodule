#!name=屏蔽iOS更新@麻辣龙虾
#!desc=阻止 iPhone/iPad 检测和下载系统更新（OTA）
#!author=ChatGPT
#!homepage=https://surge.mitsea.com
#!system=ios

[Rule]
# Apple OTA 更新服务器
DOMAIN-SUFFIX,mesu.apple.com,REJECT
DOMAIN-SUFFIX,gdmf.apple.com,REJECT
DOMAIN-SUFFIX,appldnld.apple.com,REJECT
DOMAIN-SUFFIX,updates-http.cdn-apple.com,REJECT
DOMAIN-SUFFIX,updates.cdn-apple.com,REJECT
DOMAIN-SUFFIX,xp.apple.com,REJECT
DOMAIN-SUFFIX,swscan.apple.com,REJECT
DOMAIN-SUFFIX,swcdn.apple.com,REJECT
DOMAIN-SUFFIX,swdist.apple.com,REJECT
DOMAIN-SUFFIX,swdownload.apple.com,REJECT
DOMAIN-SUFFIX,swquery.apple.com,REJECT
DOMAIN-SUFFIX,swscan-cdn.apple.com,REJECT

[Host]
# DNS 污染到本地
mesu.apple.com = 127.0.0.1
gdmf.apple.com = 127.0.0.1
appldnld.apple.com = 127.0.0.1
updates-http.cdn-apple.com = 127.0.0.1
updates.cdn-apple.com = 127.0.0.1
xp.apple.com = 127.0.0.1
swscan.apple.com = 127.0.0.1
swcdn.apple.com = 127.0.0.1
swdist.apple.com = 127.0.0.1
swdownload.apple.com = 127.0.0.1
swquery.apple.com = 127.0.0.1
swscan-cdn.apple.com = 127.0.0.1
